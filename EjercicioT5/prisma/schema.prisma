generator client {
	provider = "prisma-client-js"
}

datasource db {
	provider  = "postgresql"
	url       = env("DATABASE_URL")
	directUrl = env("DIRECT_URL")
}

enum Role {
	USER
	LIBRARIAN
	ADMIN
}

enum LoanStatus {
	ACTIVE
	RETURNED
	OVERDUE
}

model User {
	id       Int      @id @default(autoincrement())
	email    String   @unique
	name     String
	password String
	role     Role     @default(USER)
	loans    Loan[]
	reviews  Review[]
	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt

	@@map("users")
}

model Book {
	id            Int      @id @default(autoincrement())
	isbn          String   @unique
	title         String
	author        String
	genre         String
	description   String?
	publishedYear Int
	copies        Int
	available     Int
	loans         Loan[]
	reviews       Review[]
	createdAt     DateTime @default(now())
	updatedAt     DateTime @updatedAt

	@@map("books")
}

model Loan {
	id         Int        @id @default(autoincrement())
	user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
	userId     Int
	book       Book       @relation(fields: [bookId], references: [id], onDelete: Cascade)
	bookId     Int
	loanDate   DateTime   @default(now())
	dueDate    DateTime
	returnDate DateTime?
	status     LoanStatus @default(ACTIVE)

	@@index([userId])
	@@index([bookId])
	@@map("loans")
}

model Review {
	id        Int      @id @default(autoincrement())
	user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
	userId    Int
	book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
	bookId    Int
	rating    Int
	comment   String?
	createdAt DateTime @default(now())

	@@unique([userId, bookId])
	@@index([bookId])
	@@map("reviews")
}
