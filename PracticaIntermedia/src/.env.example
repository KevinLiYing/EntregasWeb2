NODE_ENV=development
PORT=3000

# Base de datos local
DATABASE_URL=mongodb://localhost:27017/miapp

# Base de datos en la nube (Mongo Atlas u otro provider)
DB_URI=mongodb+srv://<user>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_EXPIRES_IN=2h

# URLs públicas
PUBLIC_URL=http://localhost:3000