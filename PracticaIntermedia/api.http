### ==========================================
### AUTH - Registro y Login
### ==========================================

### Registrar usuario (rol: admin por defecto)
POST {{baseUrl}}/register
Content-Type: {{contentType}}

{
  "email": "kevin@ejemplo.com",
  "password": "constraseniasupersegura123",
  "name": "kevin",
  "lastName": "li",
  "nif": "12345678A"
}

### Login
POST {{baseUrl}}/login
Content-Type: {{contentType}}

{
  "email": "kevin@ejemplo.com",
  "password": "constraseniasupersegura123"
}

### ==========================================
### VALIDAR EMAIL
### ==========================================

PUT {{baseUrl}}/validation
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "code": "752552"
}

### ==========================================
### ONBOARDING DATOS PERSONALES
### ==========================================

PUT {{baseUrl}}/register
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "name": "kevin",
  "lastName": "li",
  "nif": "12345678A"
}

### ==========================================
### ONBOARDING DATOS COMPAÑÍA
### ==========================================

PATCH {{baseUrl}}/company
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "name": "Mi Empresa",
  "cif": "B12345678",
  "address": {
    "street": "Calle Falsa",
    "number": "123",
    "postal": "28080",
    "city": "Madrid",
    "province": "Madrid"
  },
  "isFreelance": false
}

### ==========================================
### SUBIR LOGO DE LA COMPAÑÍA
### ==========================================

PATCH {{baseUrl}}/logo
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=---011000010111000001101001

-----011000010111000001101001
Content-Disposition: form-data; name="logo"; filename="logo.png"
Content-Type: image/png

< ./logo.png
-----011000010111000001101001--
}

### ==========================================
### OBTENER USUARIO AUTENTICADO
### ==========================================

GET {{baseUrl}}
Authorization: Bearer {{token}}

### ==========================================
### CAMBIAR CONTRASEÑA
### ==========================================

PUT {{baseUrl}}/password
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "currentPassword": "constraseniasupersegura123",
  "newPassword": "nuevaultracontrseniasegura0123"
}

### ==========================================
### ELIMINAR USUARIO (SOFT)
### ==========================================

DELETE {{baseUrl}}?soft=true
Authorization: Bearer {{token}}

### ==========================================
### INVITAR COMPAÑERO (SOLO ADMIN)
### ==========================================

POST {{baseUrl}}/invite
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "email": "nuevo@ejemplo.com",
  "name": "Nuevo",
  "lastName": "Compañero",
  "nif": "87654321B"
}

### ==========================================
### REFRESH TOKEN
### ==========================================

POST {{baseUrl}}/refresh
Content-Type: {{contentType}}

{
  "refreshToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9"
}