### ==========================================
### HEALTH CHECK
### ==========================================

GET http://localhost:3000/health

### ==========================================
### USUARIO - REGISTRO, LOGIN, ONBOARDING, PERFIL
### ==========================================

POST http://localhost:3000/api/user/register
Content-Type: application/json

{
  "email": "admin@ejemplo.com",
  "password": "supersegura123",
  "name": "Admin",
  "lastName": "Ejemplo",
  "nif": "12345678A"
}

### Login
POST http://localhost:3000/api/user/login
Content-Type: application/json

{
  "email": "admin3@ejemplo.com",
  "password": "supersegura123"
}

### Validar email
PUT http://localhost:3000/api/user/validation
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "code": "488160"
}

### Onboarding datos personales
PUT http://localhost:3000/api/user/register
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Admin",
  "lastName": "Ejemplo",
  "nif": "12345678A"
}

### Onboarding datos compañía
PATCH http://localhost:3000/api/user/company
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Empresa S.A.",
  "cif": "B12345678",
  "address": {
    "street": "Calle Falsa",
    "number": "123",
    "postal": "28080",
    "city": "Madrid",
    "province": "Madrid"
  },
  "isFreelance": false
}

### Subir logo de la compañía
PATCH http://localhost:3000/api/user/logo
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=---011000010111000001101001

-----011000010111000001101001
Content-Disposition: form-data; name="logo"; filename="logo.png"
Content-Type: image/png

< ./logo.png
-----011000010111000001101001--
}

### Obtener usuario autenticado
GET http://localhost:3000/api/user
Authorization: Bearer {{token}}

### Cambiar contraseña
PUT http://localhost:3000/api/user/password
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "currentPassword": "supersegura123",
  "newPassword": "nuevaultrasegura456"
}

### Eliminar usuario (soft)
DELETE http://localhost:3000/api/user?soft=true
Authorization: Bearer {{token}}

### Invitar compañero (admin) // después de hacer el soft delete darle permisos de uevo para que no este en pending y este verificado
POST http://localhost:3000/api/user/invite
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "email": "nuevo@ejemplo.com",
  "name": "Nuevo",
  "lastName": "Compañero",
  "nif": "87654321B"
}

### Refresh token
POST http://localhost:3000/api/user/refresh
Content-Type: application/json

{
  "refreshToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5ZmJjNDU3YTZmNGEzMjQwYTk3ZmU1YyIsImlhdCI6MTc3ODEwNzQ5MCwiZXhwIjoxNzc4NzEyMjkwfQ.ttITA4f37RngkZ3-n9-eV7LVt23hw2AkfF2AXK2jDTI"
}

### ==========================================
### CLIENTES
### ==========================================
POST http://localhost:3000/api/client
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Cliente Ejemplo",
  "cif": "B12345678",
  "email": "cliente@email.com",
  "address": {
    "street": "Calle Falsa",
    "number": "123",
    "postal": "28003",
    "city": "Madrid",
    "province": "Madrid"
  }
}

### Listar clientes
GET http://localhost:3000/api/client?page=1&limit=10
Authorization: Bearer {{token}}

### Listar clientes archivados
GET http://localhost:3000/api/client/archived
Authorization: Bearer {{token}}

### Obtener cliente por ID
GET http://localhost:3000/api/client/{{clientId}}
Authorization: Bearer {{token}}

### Actualizar cliente
PUT http://localhost:3000/api/client/{{clientId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Cliente Actualizado"
}

### Archivar cliente
DELETE http://localhost:3000/api/client/{{clientId}}
Authorization: Bearer {{token}}

### Restaurar cliente
PATCH http://localhost:3000/api/client/{{clientId}}/restore
Authorization: Bearer {{token}}

### ==========================================
### PROYECTOS
### ==========================================
POST http://localhost:3000/api/project
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Proyecto Ejemplo",
  "code": "PRJ-001",
  "client": "{{clientId}}",
  "address": {
    "street": "Calle Nueva",
    "number": "7",
    "postal": "28004",
    "city": "Madrid",
    "province": "Madrid"
  }
}

### Listar proyectos
GET http://localhost:3000/api/project?page=1&limit=10
Authorization: Bearer {{token}}

### Listar proyectos archivados
GET http://localhost:3000/api/project/archived
Authorization: Bearer {{token}}

### Obtener proyecto por ID
GET http://localhost:3000/api/project/{{projectId}}
Authorization: Bearer {{token}}

### Actualizar proyecto
PUT http://localhost:3000/api/project/{{projectId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Proyecto Actualizado"
}

### Archivar proyecto
DELETE http://localhost:3000/api/project/{{projectId}}
Authorization: Bearer {{token}}

### Restaurar proyecto
PATCH http://localhost:3000/api/project/{{projectId}}/restore
Authorization: Bearer {{token}}

### ==========================================
### ALBARANES (DELIVERY NOTES)
### ==========================================
POST http://localhost:3000/api/deliverynote
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "project": "{{projectId}}",
  "format": "material",
  "entries": [
    {
      "material": "Cemento",
      "quantity": 10,
      "description": "Entrega de material"
    }
  ],
  "workDate": "2026-05-03"
}

### Listar albaranes
GET http://localhost:3000/api/deliverynote?page=1&limit=10
Authorization: Bearer {{token}}

### Obtener albarán por ID
GET http://localhost:3000/api/deliverynote/{{deliveryNoteId}}
Authorization: Bearer {{token}}

### Descargar PDF de albarán
GET http://localhost:3000/api/deliverynote/pdf/{{deliveryNoteId}}
Authorization: Bearer {{token}}

### Firmar albarán (multipart)
PATCH http://localhost:3000/api/deliverynote/{{deliveryNoteId}}/sign
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=---011000010111000001101001

-----011000010111000001101001
Content-Disposition: form-data; name="signature"; filename="firma.png"
Content-Type: image/png

< ./firma.png
-----011000010111000001101001--

### Borrar albarán
DELETE http://localhost:3000/api/deliverynote/{{deliveryNoteId}}
Authorization: Bearer {{token}}

### ==========================================
### SWAGGER UI
### ==========================================
GET http://localhost:3000/api-docs